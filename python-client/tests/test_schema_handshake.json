                  },
                  "message": {
                    "type": "string"
                  }
                },
                "required": [
                  "code",
                  "message"
                ]
              },
              {
                "type": "object",
                "properties": {
                  "code": {
                    "const": "UNEXPECTED_DISCONNECT",
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  }
                },
                "required": [
                  "code",
                  "message"
                ]
              },
              {
                "type": "object",
                "properties": {
                  "code": {
                    "const": "INVALID_REQUEST",
